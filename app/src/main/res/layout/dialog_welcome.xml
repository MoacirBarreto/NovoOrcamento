<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    android:background="@drawable/bg_lume_soft"
    android:elevation="8dp"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- TÍTULO: Agora com cor marrom escuro para combinar com o dourado -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/bem_vindo"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#3E2723"
            android:layout_gravity="center"
            android:layout_marginBottom="20dp" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/planeje"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#3E2723"
            android:layout_gravity="center"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/voce_manda"
            android:textColor="#4E342E"
            android:textSize="16sp"
            android:layout_marginBottom="16dp" />

        <!-- SEÇÃO DE INSTRUÇÕES -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/lancamentos_clique"
            android:textColor="#5D4037"
            android:layout_marginBottom="10dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/agenda_planeje_o_futuro"
            android:textColor="#5D4037"
            android:layout_marginBottom="16dp" />

        <!-- AVISO DE ATENÇÃO: Vermelho mais suave para não ser agressivo -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/atencao"
            android:textColor="#B71C1C"
            android:textStyle="italic"
            android:textSize="14sp"
            android:layout_marginBottom="20dp" />

        <!-- MENSAGEM IMPORTANTE: Azul marinho para dar autoridade -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/importante"
            android:textColor="#1A237E"
            android:textStyle="bold"
            android:textSize="15sp"
            android:layout_marginBottom="24dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#20000000"
            android:layout_marginBottom="16dp" />

        <!-- CHECKBOX: Cor de texto neutra -->
        <CheckBox
            android:id="@+id/chkNaoMostrarNovamente"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/entendi_tudo"
            android:textColor="#3E2723"
            android:buttonTint="#FFA000" />

        <!-- BOTÃO PRINCIPAL: Agora com margem superior maior para destaque -->
        <Button
            android:id="@+id/btnEntendido"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="@string/vamos_comecar"
            android:textSize="16sp"
            android:textAllCaps="true"
            android:textStyle="bold"
            android:backgroundTint="#FF6F00"
            android:textColor="@android:color/white"
            android:layout_marginTop="20dp" />

    </LinearLayout>
</ScrollView>